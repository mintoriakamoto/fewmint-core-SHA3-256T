{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cooklabs.dev/schemas/v1/hercules-task.schema.json",
  "title": "Hercules Task",
  "description": "A Software Factory task record and its worker context package. See spec 09-hercules-protocol.md.",
  "type": "object",
  "required": ["task_id", "title", "specification", "owner", "branch", "allowed_paths", "acceptance_criteria", "status"],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9]*-\\d+$",
      "description": "e.g. 'ARCH-001', 'DB-001', 'REVIEW-001'."
    },
    "epic_id": { "type": "string", "pattern": "^[A-Z][A-Z0-9-]*-\\d+$", "description": "e.g. 'AUTO-SAAS-001'." },
    "title": { "type": "string", "minLength": 1 },
    "specification": { "type": "string", "minLength": 1, "description": "What to build and why; the normative task spec." },
    "owner": {
      "type": "string",
      "description": "Assigned worker id, e.g. 'claude_code', 'codex', 'hermes', 'mimocode', 'grok_build', 'local'."
    },
    "branch": { "type": "string", "minLength": 1 },
    "worktree": { "type": "string", "description": "Isolated worktree path for this task." },
    "dependencies": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[A-Z][A-Z0-9]*-\\d+$" },
      "description": "Task ids that must complete first (edges of the DAG)."
    },
    "allowed_paths": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "description": "Glob paths the worker may modify. Writes outside these are protocol violations."
    },
    "forbidden_changes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Explicit prohibitions (interfaces, files, patterns) from the context package."
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "tests": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Test commands/suites that must pass for this task."
    },
    "security_requirements": {
      "type": "array",
      "items": { "type": "string" }
    },
    "context": {
      "type": "object",
      "description": "Remaining context-package fields (spec 09 §4).",
      "properties": {
        "relevant_files": { "type": "array", "items": { "type": "string" } },
        "architecture_rules": { "type": "array", "items": { "type": "string" } },
        "interfaces": { "type": "array", "items": { "type": "string" } },
        "expected_output": { "type": "string" }
      },
      "additionalProperties": false
    },
    "budget": {
      "type": "object",
      "properties": {
        "max_cost_usd": { "type": "number", "exclusiveMinimum": 0 },
        "max_tokens": { "type": "integer", "exclusiveMinimum": 0 }
      },
      "additionalProperties": false
    },
    "deadline": { "type": "string", "format": "date-time" },
    "status": {
      "enum": [
        "draft", "ready", "assigned", "in_progress", "self_test",
        "in_review", "gates", "evaluation", "pr_open", "merged",
        "rejected", "cancelled"
      ]
    },
    "review": {
      "type": "object",
      "description": "Cross-model verification plan (spec 09 §5).",
      "properties": {
        "reviewers": { "type": "array", "items": { "type": "string" }, "description": "Must differ from owner for critical tasks." },
        "competitive": { "type": "boolean", "description": "True when two workers solve independently." }
      },
      "additionalProperties": false
    },
    "artifacts": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Commits, PR links, test/benchmark/security reports recorded as evidence."
    }
  },
  "additionalProperties": false
}
