{
  "name": "cooklabs",
  "version": "0.1.0",
  "private": true,
  "description": "Cook Labs — AI Business Operating System monorepo",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "format": "prettier --write \"packages/**/*.ts\"",
    "format:check": "prettier --check \"packages/**/*.ts\"",
    "lint": "eslint packages",
    "typecheck": "tsc -b",
    "build": "tsc -b",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.0",
    "eslint": "^9.17.0",
    "pg": "^8.13.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.19.0",
    "vitest": "^2.1.0"
  }
}
